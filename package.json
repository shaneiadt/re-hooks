{
  "name": "use-re-hooks",
  "version": "2.0.0",
  "description": "React custom hooks library",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "author": "Shane O'Moore",
  "email": "shaneiadt@gmail.com",
  "url": "https://shaneiadt.github.io/",
  "repository": {
    "type": "git",
    "url": "https://github.com/shaneiadt/re-hooks"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "playground:dev": "bun run build && bun run --cwd playground dev",
    "playground:build": "bun run build && bun run --cwd playground build",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "release": "bun run release:dry-run && npm publish --access public",
    "release:check": "bun run typecheck && bun run test && bun run build",
    "release:dry-run": "bun run release:check && npm pack --dry-run",
    "prepublishOnly": "bun run typecheck && bun run test && bun run build"
  },
  "peerDependencies": {
    "react": "^18 || ^19"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@types/react": "^19.1.13",
    "@types/react-dom": "^19.1.9",
    "jsdom": "26.1.0",
    "react-dom": "^19.2.0",
    "tsup": "^8.5.0",
    "typescript": "^5.9.2",
    "vitest": "3.2.4"
  },
  "keywords": [
    "react",
    "hooks"
  ],
  "volta": {
    "node": "24.14.0",
    "bun": "1.3.10"
  }
}
